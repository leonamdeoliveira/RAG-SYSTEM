# LM Studio (OCR + LLM)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=glm-ocr
LMSTUDIO_API_KEY=

# ===== RAG System =====
# Caminhos
RAG_DATA_DIR=data
RAG_MARKDOWN_DIR=markdown
RAG_INDEX_DIR=index

# Chunker
RAG_CHUNKER_TARGET_TOKENS=600
RAG_CHUNKER_MIN_TOKENS=80
RAG_CHUNKER_MAX_TOKENS=800
RAG_CHUNKER_OVERLAP_RATIO=0.15

# Embeddings (BGE-M3)
RAG_EMBEDDING_PROVIDER=local
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_EMBEDDING_DIMENSION=1024
RAG_EMBEDDING_DEVICE=cpu
RAG_EMBEDDING_USE_FP16=false
RAG_EMBEDDING_ENABLE_SPARSE=true
RAG_EMBEDDING_BATCH_SIZE=32
# Backend: "onnx" (onnxruntime, ~570 MB, recomendado) ou "torch" (sentence-transformers)
# ONNX: pip install onnxruntime huggingface-hub transformers
# Torch: pip install sentence-transformers torch
RAG_EMBEDDING_BACKEND=onnx
RAG_EMBEDDING_MODEL_ONNX=gpahal/bge-m3-onnx-int8

# Zvec
RAG_ZVEC_ENABLE_SPARSE=true

# Retrieval
RAG_RETRIEVAL_TOP_K=20
RAG_RETRIEVAL_SCORE_THRESHOLD=0.0
RAG_RETRIEVAL_MAX_CONTEXT_CHUNKS=8
RAG_RETRIEVAL_MAX_PER_DOC=3
RAG_RETRIEVAL_MODE=hybrid
# Reranker local desativado por padrao — o chat IA faz o reranking
# Ative apenas se for usar `query` standalone com LLM local
RAG_RETRIEVAL_RERANK=false

# Reranker (cross-encoder ONNX INT8; desativado por padrao — chat IA faz o reranking)
RAG_RERANK_ENABLED=false
RAG_RERANK_MODEL=suhaan7988/bge-reranker-v2-m3-int8-onnx
RAG_RERANK_DEVICE=cpu
RAG_RERANK_MAX_LENGTH=1024
RAG_RERANK_TOP_N_CANDIDATES=20

# LLM (OpenAI-compatible: LM Studio / Ollama / vLLM)
RAG_LLM_BASE_URL=http://localhost:1234/v1
RAG_LLM_API_KEY=
RAG_LLM_MODEL=local
RAG_LLM_TIMEOUT=60.0
RAG_LLM_TEMPERATURE=0.2
RAG_LLM_MAX_TOKENS=700
RAG_ANSWER_MODE=answer_with_citations

# Reliability
RAG_RELIABILITY_LOW_CONFIDENCE_THRESHOLD=0.3
RAG_RELIABILITY_EXPAND_FACTOR=2
RAG_RELIABILITY_MAX_RETRIES=1

# OCR (Tesseract + LM Studio)
RAG_OCR_MODE=hybrid
RAG_OCR_MODEL=glm-ocr
RAG_OCR_QUALITY_THRESHOLD=0.70
RAG_OCR_LANGS=por+eng
RAG_OCR_DPI=200
RAG_OCR_TIMEOUT=300
RAG_OCR_RETRIES=3
RAG_OCR_USE_LAYOUT=true

# Logging
RAG_LOG_LEVEL=INFO
